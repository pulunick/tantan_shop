# =============================================================================
# 환경변수 예시 — 실제 값은 .env 에 채운다 (.env 는 커밋 금지, dev 키만 로컬 보관)
# Supabase 신규 API 키 체계 사용 (legacy anon/service_role 없음)
#   대시보드: Project Settings → API Keys 에서 확인
# =============================================================================

# 공개 가능 (클라이언트 번들에 포함됨)
PUBLIC_SUPABASE_URL=https://<your-dev-ref>.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# 서버 전용 (RLS 우회). PUBLIC_ 접두사 금지 — 절대 클라이언트로 노출하지 말 것
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
